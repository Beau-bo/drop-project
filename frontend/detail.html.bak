<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>项目详情 | 废项局</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen">
    <header class="border-b border-slate-800 sticky top-0 bg-slate-900/95 backdrop-blur z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-white rounded flex items-center justify-center text-slate-900 font-bold">废</div>
                    <span class="font-bold text-xl text-slate-100">废项局 <span class="text-slate-400 font-normal text-sm">| Drop Project</span></span>
                </div>
                <div class="flex items-center gap-4">
                    <a href="index.html" class="px-4 py-2 bg-white text-slate-900 hover:bg-slate-200 rounded-lg text-sm font-medium">返回列表</a>
                    <a href="profile.html" class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center overflow-hidden">
                        <img id="nav-avatar" src="" alt="" class="w-full h-full object-cover hidden">
                        <span id="nav-avatar-text" class="text-slate-300 font-medium text-sm">U</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="border border-slate-600 rounded-xl p-8 bg-slate-800/50">
            <div id="projectDetail" class="space-y-6">
                <div class="flex flex-wrap gap-4 mb-4">
                    <span id="typeTag" class="px-3 py-1 bg-blue-900/30 text-xs rounded text-blue-400">代码尸骸</span>
                    <span id="diffTag" class="px-3 py-1 bg-slate-700 text-xs rounded text-slate-300">局部修复</span>
                    <span id="projectIdTag" class="px-3 py-1 bg-slate-900 text-xs rounded text-slate-400">项目ID: 1</span>
                </div>
                <h1 id="projectTitle" class="text-3xl font-bold mb-6">AI 客服 SaaS 半成品</h1>
                <div class="prose prose-invert max-w-none">
                    <p id="projectDesc" class="text-slate-300 text-lg">
                        基于 GPT-4 的智能客服系统，已完成核心对话引擎和多渠道接入，因资金链断裂停止开发。
                        包含完整的对话流程设计、用户意图识别、多轮对话管理功能，支持微信、网页、APP 多端接入，
                        后端使用 Node.js + MongoDB，前端使用 React + TypeScript，代码结构清晰，注释完整。
                    </p>
                </div>
                <div class="mt-8 pt-6 border-t border-slate-700">
                    <h3 class="text-xl font-semibold mb-4">项目详情信息</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-slate-900/50 p-4 rounded-lg">
                            <span class="text-slate-400 text-sm">开发状态</span>
                            <p class="text-slate-200 mt-1">80% 完成度</p>
                        </div>
                        <div class="bg-slate-900/50 p-4 rounded-lg">
                            <span class="text-slate-400 text-sm">技术栈</span>
                            <p class="text-slate-200 mt-1">Node.js、MongoDB、React、TypeScript</p>
                        </div>
                        <div class="bg-slate-900/50 p-4 rounded-lg">
                            <span class="text-slate-400 text-sm">废弃原因</span>
                            <p class="text-slate-200 mt-1">资金链断裂</p>
                        </div>
                        <div class="bg-slate-900/50 p-4 rounded-lg">
                            <span class="text-slate-400 text-sm">复活建议</span>
                            <p class="text-slate-200 mt-1">补充资金，完善支付和权限模块</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        // 获取URL中的项目ID参数
        function getProjectIdFromUrl() {
            const params = new URLSearchParams(window.location.search);
            return params.get('id') || '1';
        }

        // 模拟项目详情数据（实际项目中可从API获取）
        const projectData = {
            1: {
                title: "AI 客服 SaaS 半成品",
                type: "代码尸骸",
                diff: "局部修复",
                desc: "基于 GPT-4 的智能客服系统，已完成核心对话引擎和多渠道接入，因资金链断裂停止开发。包含完整的对话流程设计、用户意图识别、多轮对话管理功能，支持微信、网页、APP 多端接入，后端使用 Node.js + MongoDB，前端使用 React + TypeScript，代码结构清晰，注释完整。"
            },
            2: {
                title: "企业官网开发项目",
                type: "代码尸骸",
                diff: "局部修复",
                desc: "响应式企业官网，含产品展示、后台管理，因合作终止废弃。使用 Vue3 + Vite 开发，包含首页、产品列表、产品详情、关于我们、联系我们等页面，后台使用 Express + MySQL 实现基础的内容管理功能，代码模块化程度高，易于扩展。"
            },
            3: {
                title: "在线教育学习系统",
                type: "代码尸骸",
                diff: "局部修复",
                desc: "课程、考试、题库一体化学习平台，技术迭代废弃。基于 Spring Boot + Vue3 开发，支持课程视频播放、章节练习、在线考试、成绩统计等功能，用户体系包含学生、教师、管理员三种角色，权限控制完善。"
            },
            50: {
                title: "AI 客服机器人",
                type: "概念泡沫",
                diff: "局部修复",
                desc: "智能客服概念，因效果不佳调整。基于大语言模型的智能客服机器人原型设计，包含意图识别、知识库问答、多轮对话等核心功能设计文档，未进入开发阶段，可基于现有设计文档进行技术落地。"
            }
        };

        // 初始化详情页
        function initDetailPage() {
            const projectId = getProjectIdFromUrl();
            const project = projectData[projectId] || projectData[1];
            
            // 更新页面内容
            document.getElementById('projectTitle').textContent = project.title;
            document.getElementById('projectDesc').textContent = project.desc;
            document.getElementById('typeTag').textContent = project.type;
            document.getElementById('diffTag').textContent = project.diff;
            document.getElementById('projectIdTag').textContent = `项目ID: ${projectId}`;
            
            // 根据类型设置标签样式
            const typeTag = document.getElementById('typeTag');
            switch(project.type) {
                case "代码尸骸":
                    typeTag.className = "px-3 py-1 bg-blue-900/30 text-xs rounded text-blue-400";
                    break;
                case "原型幽灵":
                    typeTag.className = "px-3 py-1 bg-purple-900/30 text-xs rounded text-purple-400";
                    break;
                case "运营废墟":
                    typeTag.className = "px-3 py-1 bg-indigo-900/30 text-xs rounded text-indigo-400";
                    break;
                case "设计遗稿":
                    typeTag.className = "px-3 py-1 bg-pink-900/30 text-xs rounded text-pink-400";
                    break;
                case "概念泡沫":
                    typeTag.className = "px-3 py-1 bg-yellow-900/30 text-xs rounded text-yellow-400";
                    break;
            }

            // 根据难度设置标签样式
            const diffTag = document.getElementById('diffTag');
            switch(project.diff) {
                case "快速激活":
                    diffTag.className = "px-3 py-1 bg-orange-900/30 text-xs rounded text-orange-400";
                    break;
                case "局部修复":
                    diffTag.className = "px-3 py-1 bg-slate-700 text-xs rounded text-slate-300";
                    break;
                case "推倒重来":
                    diffTag.className = "px-3 py-1 bg-red-900/30 text-xs rounded text-red-400";
                    break;
                case "仅供参考":
                    diffTag.className = "px-3 py-1 bg-slate-700 text-xs rounded text-slate-300";
                    break;
            }
        }

        // 页面加载完成后初始化
        window.addEventListener('DOMContentLoaded', initDetailPage);
    </script>
</body>
</html>
